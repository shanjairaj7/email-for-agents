# Commune — get your API key at https://commune.sh/dashboard
COMMUNE_API_KEY=comm_...

# Phone number to send SMS from — provision in the Commune dashboard
COMMUNE_PHONE_NUMBER_ID=pn_...

# Inbox used to send the sales team summary email
COMMUNE_INBOX_ID=inbox_...

# OpenAI — used to score and summarise the qualification conversation
OPENAI_API_KEY=sk-...

# Where to email qualified lead summaries
SALES_EMAIL=sales@yourcompany.com

# HTTP server port
PORT=3000
