# Commune — get your API key at https://commune.sh/dashboard
COMMUNE_API_KEY=comm_...

# Inbox to send from — create one in the dashboard or via the SDK
COMMUNE_INBOX_ID=inbox_...

# OpenAI — used to generate personalised newsletter content
OPENAI_API_KEY=sk-...

# Displayed in the From: header of every email
NEWSLETTER_NAME=The Weekly Dispatch
FROM_NAME=Your Name
