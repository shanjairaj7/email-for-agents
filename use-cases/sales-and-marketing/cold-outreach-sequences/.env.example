# Commune — get your API key at https://commune.sh/dashboard
COMMUNE_API_KEY=comm_...

# The inbox to send from — create one in the dashboard or via the SDK
COMMUNE_INBOX_ID=inbox_...

# OpenAI — used to personalize each email
OPENAI_API_KEY=sk-...

# Sender identity shown in outgoing emails
FROM_NAME=Alex Johnson
FROM_COMPANY=Acme Corp
