    "## Section 8: TypeScript Equivalent\n",
    "\n",
    "### The Same Thread Pattern in commune-ai (TypeScript)\n",
    "\n",
    "If your LangChain agent is in Python but your frontend or other services are in TypeScript, here is the equivalent thread_id pattern using `commune-ai`. The logic is identical — just expressed in TypeScript.\n",
    "\n",
    "> **Cross-reference:** The `typescript/` folder in this repo has a complete TypeScript agent example. The thread_id pattern below maps directly to `typescript/agent.ts`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "aa100030",
   "metadata": {},
   "outputs": [],
   "source": [
    "typescript_example = \"\"\"\n",
    "// Install: npm install commune-ai\n",
    "import { CommuneClient } from 'commune-ai';\n",
    "\n",
    "const client = new CommuneClient({ apiKey: process.env.COMMUNE_API_KEY! });\n",
    "\n",
    "// Thread state (use Redis/DB in production — same pattern as Python)\n",
    "const threadStore = new Map<string, string>(); // contactEmail → thread_id\n",
    "\n",
    "// ✅ CORRECT: First email — no thread_id\n",
    "async function sendFirstEmail(to: string, subject: string, body: string): Promise<string> {\n",
    "  const result = await client.messages.send({\n",
    "    fromInboxId: process.env.COMMUNE_INBOX_ID!,\n",
    "    to,\n",
    "    subject,\n",
    "    text: body,\n",
    "    // threadId intentionally omitted — new thread\n",
    "  });\n",
    "\n",
    "  // Store immediately after send\n",
    "  threadStore.set(to, result.threadId);\n",
    "  return result.threadId;\n",
    "}\n",
    "\n",
    "// ✅ CORRECT: Reply — always pass threadId\n",
    "async function replyToContact(to: string, body: string): Promise<void> {\n",
    "  const threadId = threadStore.get(to);\n",
    "  if (!threadId) {\n",
    "    throw new Error(`No existing thread for ${to}. Use sendFirstEmail first.`);\n",
    "  }\n",
    "\n",
    "  await client.messages.send({\n",
    "    fromInboxId: process.env.COMMUNE_INBOX_ID!,\n",
    "    threadId, // ← always provided for replies\n",
    "    text: body,\n",
    "  });\n",
    "}\n",
    "\n",
    "// ✅ CORRECT: Webhook handler — extract threadId, pass to reply\n",
    "// Express example:\n",
    "app.post('/webhook/commune', async (req, res) => {\n",
    "  // 1. Verify signature\n",
    "  const sig = req.headers['x-commune-signature'] as string;\n",
    "  if (!verifySignature(req.rawBody, sig, process.env.COMMUNE_WEBHOOK_SECRET!)) {\n",
    "    return res.status(401).json({ error: 'Invalid signature' });\n",
    "  }\n",
    "\n",
    "  // 2. Return 200 IMMEDIATELY\n",
    "  res.status(200).json({ status: 'received' });\n",
    "\n",
    "  // 3. Process in background (don't await before sending 200)\n",
    "  const { message } = req.body.payload;\n",
    "  const threadId = message.thread_id; // use this for the reply\n",
    "  const replyBody = await generateAgentReply(message.text); // your LLM call\n",
    "\n",
    "  await client.messages.send({\n",
    "    fromInboxId: process.env.COMMUNE_INBOX_ID!,\n",
    "    threadId,    // ← from webhook payload, not from local state\n",
    "    text: replyBody,\n",
    "  });\n",
    "});\n",
    "\"\"\"\n",
    "\n",
    "print(typescript_example)"
   ]
