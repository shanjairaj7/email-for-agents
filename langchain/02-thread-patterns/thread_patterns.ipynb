    "    payload[\"id\"] = \"evt_reply_001\"\n",
    "    payload[\"payload\"] = dict(payload[\"payload\"])\n",
    "    payload[\"payload\"][\"message\"] = dict(payload[\"payload\"][\"message\"])\n",
    "    payload[\"payload\"][\"message\"][\"id\"] = \"msg_incoming_002\"\n",
    "    payload[\"payload\"][\"message\"][\"text\"] = \"Thanks, follow-up question here.\"\n",
    "    payload[\"payload\"][\"message\"][\"subject\"] = \"Re: Question about my account\"\n",
    "    # thread_id is SAME as first message — this is how Commune works\n",
    "    return payload\n",
    "\n",
    "\n",
    "# Tests\n",
    "\n",
    "class TestThreadIdPersistence:\n",
    "\n",
    "    def test_thread_id_stored_after_first_send(self, mock_commune_client):\n",
    "        \"\"\"After sending the first email, thread_id must be stored.\"\"\"\n",
    "        store = InMemoryThreadStore()\n",
    "        send_first_email(\n",
    "            inbox_id=\"inb_test\",\n",
    "            to=\"customer@example.com\",\n",
    "            subject=\"Hello\",\n",
    "            body=\"Welcome!\",\n",
    "            thread_store=store,\n",
    "        )\n",
    "        stored = store.get(\"contact:customer@example.com\")\n",
    "        assert stored == \"th_abc123testthread\", f\"Expected thread_id, got: {stored}\"\n",
    "\n",
    "    def test_reply_uses_stored_thread_id(self, mock_commune_client, webhook_payload_first_message):\n",
    "        \"\"\"A reply to a webhook MUST pass the correct thread_id.\"\"\"\n",
    "        store = InMemoryThreadStore()\n",
    "        store.set(\"contact:customer@example.com\", \"th_abc123testthread\")\n",
    "\n",
    "        handle_incoming_webhook(\n",
    "            payload=webhook_payload_first_message[\"payload\"],\n",
    "            inbox_id=\"inb_test\",\n",
    "            body=\"Here is your answer.\",\n",
    "            thread_store=store,\n",
    "        )\n",
    "\n",
    "        # Assert that send was called with the correct thread_id\n",
    "        call_kwargs = mock_commune_client.messages.send.call_args.kwargs\n",
    "        assert call_kwargs[\"thread_id\"] == \"th_abc123testthread\", (\n",
    "            f\"Expected thread_id=th_abc123testthread, got thread_id={call_kwargs.get('thread_id')}\"\n",
    "        )\n",
    "\n",
    "    def test_no_thread_id_on_first_send(self, mock_commune_client):\n",
    "        \"\"\"First email must NOT include thread_id — it starts a new thread.\"\"\"\n",
    "        store = InMemoryThreadStore()\n",
    "        send_first_email(\n",
    "            inbox_id=\"inb_test\",\n",
    "            to=\"newcustomer@example.com\",\n",
    "            subject=\"Welcome\",\n",
    "            body=\"Hi!\",\n",
    "            thread_store=store,\n",
    "        )\n",
    "        call_kwargs = mock_commune_client.messages.send.call_args.kwargs\n",
    "        assert \"thread_id\" not in call_kwargs or call_kwargs[\"thread_id\"] is None, (\n",
    "            \"First send should NOT include thread_id\"\n",
    "        )\n",
    "\n",
    "    def test_second_reply_uses_same_thread_id(self, mock_commune_client, webhook_payload_reply):\n",
    "        \"\"\"Second reply in a conversation MUST use the same thread_id as the first.\"\"\"\n",
    "        store = InMemoryThreadStore()\n",
    "        # Pre-populate as if a previous exchange already occurred\n",
    "        store.set(\"contact:customer@example.com\", \"th_abc123testthread\")\n",
    "\n",
    "        handle_incoming_webhook(\n",
    "            payload=webhook_payload_reply[\"payload\"],\n",
    "            inbox_id=\"inb_test\",\n",
    "            body=\"Follow-up answer.\",\n",
    "            thread_store=store,\n",
    "        )\n",
    "\n",
    "        call_kwargs = mock_commune_client.messages.send.call_args.kwargs\n",
    "        # Thread_id should be the ORIGINAL thread, not a new one\n",
    "        assert call_kwargs[\"thread_id\"] == \"th_abc123testthread\"\n",
    "\n",
    "'''\n",
    "\n",
    "with open(\"/tmp/test_thread_continuity.py\", \"w\") as f:\n",
    "    f.write(test_code)\n",
    "\n",
    "print(\"Tests written to /tmp/test_thread_continuity.py\")\n",
    "print()\n",
    "print(\"Run with: pytest /tmp/test_thread_continuity.py -v\")\n",
    "print()\n",
    "print(\"These tests catch all 3 mistakes from Section 3:\")\n",
    "print(\"  - test_thread_id_stored_after_first_send → catches Mistake 3\")\n",
    "print(\"  - test_reply_uses_stored_thread_id → catches Mistake 1\")\n",
    "print(\"  - test_no_thread_id_on_first_send → prevents accidental thread reuse\")\n",
    "print(\"  - test_second_reply_uses_same_thread_id → catches subject-drift bug (Mistake 2)\")"
   ]
