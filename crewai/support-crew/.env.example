# Commune API key — get yours at https://commune.email
COMMUNE_API_KEY=comm_your_key_here

# OpenAI API key — used by CrewAI agents
# CrewAI uses gpt-4o by default; set OPENAI_MODEL_NAME to override.
OPENAI_API_KEY=sk-your_key_here

# Optional: override the LLM model used by CrewAI agents
# OPENAI_MODEL_NAME=gpt-4o-mini
