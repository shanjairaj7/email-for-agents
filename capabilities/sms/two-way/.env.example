# Commune API key — get from https://commune.email/dashboard
COMMUNE_API_KEY=comm_...

# The phone number that will receive inbound SMS
# Find the ID in the dashboard: Phone Numbers → your number → ID
COMMUNE_PHONE_NUMBER_ID=pn_...

# OpenAI API key — used to generate replies
OPENAI_API_KEY=sk_...

# Port for the webhook handler server (default: 3000)
PORT=3000
