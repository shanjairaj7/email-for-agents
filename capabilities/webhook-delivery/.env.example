# Commune API key — get from https://commune.email/dashboard
COMMUNE_API_KEY=comm_...

# Webhook signing secret — copy from Commune dashboard after running webhook-setup.ts
# Settings → Webhooks → your endpoint → Show secret
COMMUNE_WEBHOOK_SECRET=whsec_...

# Public URL for your webhook handler — used during setup only
# Must be publicly reachable (e.g. a Railway, Fly, or ngrok URL)
WEBHOOK_URL=https://your-app.railway.app/webhook

# Port for the webhook handler server (default: 3000)
PORT=3000
